[Unit]
Description=MiniBMC Redfish API
After=minibmc.service
Requires=minibmc.service

[Service]
ExecStart=/home/renzoval/minibmc/redfish/venv/bin/uvicorn api:app --host 0.0.0.0 --port 8000
WorkingDirectory=/home/renzoval/minibmc/redfish
Restart=on-failure
RestartSec=3
User=root

[Install]
WantedBy=multi-user.target
